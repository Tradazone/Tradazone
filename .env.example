# ─────────────────────────────────────────────────────────────────────────────
# Tradazone — Environment Variable Reference
#
# Copy this file to .env.development or .env.local and fill in values.
# Files named .env.*.local are git-ignored and safe for secrets.
# Vite only exposes VITE_* variables to the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────

# App environment: development | staging | production
VITE_APP_ENV=development

# Base URL path — must match deployment sub-path
# development : /
# production  : / (when using a custom domain like app.tradazone.com)
VITE_BASE_PATH=/

# Backend API base URL
# development : http://localhost:3000/api
# production  : https://api.tradazone.com/api
VITE_API_URL=http://localhost:3000/api

# Webhook endpoint for checkout lifecycle events (optional)
VITE_WEBHOOK_URL=

# App display name shown in UI
VITE_APP_NAME=Tradazone

# SEP-38 Stellar Anchor Quote Server base URL
VITE_SEP38_URL=

# EmailJS — get from https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_TEMPLATE_INVOICE=
VITE_EMAILJS_TEMPLATE_RECEIPT=
